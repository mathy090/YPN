{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_AI_URL": "http://localhost:4000",
        "EXPO_PUBLIC_ENV": "development"
      }
    },

    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ypn.onrender.com",
        "EXPO_PUBLIC_AI_URL": "https://ypn-1.onrender.com",
        "EXPO_PUBLIC_ENV": "preview"
      }
    },

    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ypn.onrender.com",
        "EXPO_PUBLIC_AI_URL": "https://ypn-1.onrender.com",
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
